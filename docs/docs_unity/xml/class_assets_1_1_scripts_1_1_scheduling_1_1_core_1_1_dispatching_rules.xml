        <type>int</type>
        <definition>static int Assets.Scripts.Scheduling.Core.DispatchingRules.RemainingWork</definition>
        <argsstring>(Operation op, Job[] allJobs)</argsstring>
        <name>RemainingWork</name>
        <qualifiedname>Assets.Scripts.Scheduling.Core.DispatchingRules.RemainingWork</qualifiedname>
        <param>
          <type><ref refid="class_assets_1_1_scripts_1_1_scheduling_1_1_core_1_1_operation" kindref="compound">Operation</ref></type>
          <declname>op</declname>
        </param>
        <param>
          <type><ref refid="class_assets_1_1_scripts_1_1_scheduling_1_1_core_1_1_job" kindref="compound">Job</ref>[]</type>
          <declname>allJobs</declname>
        </param>
        <briefdescription>
<para>Computes the total remaining processing time for a job from a given operation onward. </para>
        </briefdescription>
        <detaileddescription>
<para>Sums <ref refid="class_assets_1_1_scripts_1_1_scheduling_1_1_core_1_1_operation_1a33c6d6f8ca03df6cacc3cae0ba540b18" kindref="member">Operation.Duration</ref> for every operation at or after <computeroutput>op&apos;s</computeroutput> index in the job&apos;s operation sequence. Used as the sort key for <ref refid="namespace_assets_1_1_scripts_1_1_scheduling_1_1_core_1af841dd07c9c38276e117696a4dd6fe87a9207d43f78389b34a02df21e4c33f724" kindref="member">DispatchingRule.SRT_SRWT</ref>, <ref refid="namespace_assets_1_1_scripts_1_1_scheduling_1_1_core_1af841dd07c9c38276e117696a4dd6fe87a43f08a6810a17732c5bf5f20644ca7d6" kindref="member">DispatchingRule.SRT_SMPT</ref>, and <ref refid="namespace_assets_1_1_scripts_1_1_scheduling_1_1_core_1af841dd07c9c38276e117696a4dd6fe87a3ead285f50958d8aa6e59cf3fe61b421" kindref="member">DispatchingRule.LRT_MMUR</ref>.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>op</parametername>
</parameternamelist>
<parameterdescription>
<para>The reference operation whose index marks the start of summation. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>allJobs</parametername>
</parameternamelist>
<parameterdescription>
<para>The full job array used to retrieve the owning job&apos;s operation sequence.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para>The sum of durations for all remaining operations, including <computeroutput>op</computeroutput> itself. </para>
</simplesect>
</para>
        </detaileddescription>
